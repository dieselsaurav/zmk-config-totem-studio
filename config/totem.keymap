//
//                                                        ▀▀▀▀▀     ▀▀▀▀▀          ▀▀█▀▀
//                                                        ▄▀▀▀▄  ▄  ▄▀▀▀▄  ▄  ▄▀▀▀▄  █  ▄▀▀▀▄
//                                                        █   █  █  █   █  █  █   █  █  █   █
//                                                         ▀▀▀   █   ▀▀▀   █   ▀▀▀   ▀   ▀▀▀
//                                                               █      ▄▄▄█▄▄▄    █   █
//                                                               ▀      █  █  █     █▄█
//                                                             ▀▀▀▀▀    █  █  █      ▀
//                                                                      ▀  ▀  ▀
//
// ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
//
//   Miryoku-style layout — QWERTY base, vim arrows (HJKL), GACS home row mods
//
//   Layer 0: BASE    — QWERTY + home row mods
//   Layer 1: NAV     — vim arrows, clipboard, nav (hold SPACE)
//   Layer 2: NUM     — numpad left hand (hold BSPC)
//   Layer 3: MEDIA   — media, BT (hold ESC)
//   Layer 4: SYM     — symbols left hand (hold ENTER)
//   Layer 5: FUN     — function keys left hand (hold DEL)
//   Layer 6: MOUSE   — mouse movement, scroll, buttons (hold TAB)

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h>

#define BASE  0
#define NAV   1
#define NUM   2
#define MEDIA 3
#define SYM   4
#define FUN   5
#define MOUSE 6

&mt {
    flavor = "tap-preferred";
    tapping-term-ms = <200>;
    quick-tap-ms = <175>;
    require-prior-idle-ms = <150>;
};

&lt {
    flavor = "balanced";
    tapping-term-ms = <200>;
    quick-tap-ms = <175>;
};

/ {
    combos {
        compatible = "zmk,combos";

        // ── Tier 1: Essential ──────────────────────────────────────

        combo_caps_word {
            bindings = <&caps_word>;
            key-positions = <13 16>;         // F + J (index home row)
            timeout-ms = <30>;
            require-prior-idle-ms = <150>;
        };

        combo_esc {
            bindings = <&kp ESC>;
            key-positions = <1 2>;           // W + E
            timeout-ms = <30>;
            require-prior-idle-ms = <150>;
        };

        combo_bspc {
            bindings = <&kp BSPC>;
            key-positions = <7 8>;           // I + O
            timeout-ms = <30>;
            require-prior-idle-ms = <150>;
        };

        combo_del {
            bindings = <&kp DEL>;
            key-positions = <8 9>;           // O + P
            timeout-ms = <30>;
            require-prior-idle-ms = <150>;
        };

        // ── Tier 2: High Value ─────────────────────────────────────

        combo_tab {
            bindings = <&kp TAB>;
            key-positions = <11 12>;         // S + D
            timeout-ms = <30>;
            require-prior-idle-ms = <150>;
        };

        combo_enter {
            bindings = <&kp RET>;
            key-positions = <17 18>;         // K + L
            timeout-ms = <30>;
            require-prior-idle-ms = <150>;
        };

        combo_copy {
            bindings = <&kp LG(C)>;
            key-positions = <22 23>;         // X + C
            timeout-ms = <30>;
            require-prior-idle-ms = <150>;
        };

        combo_paste {
            bindings = <&kp LG(V)>;
            key-positions = <23 24>;         // C + V
            timeout-ms = <30>;
            require-prior-idle-ms = <150>;
        };

        combo_cut {
            bindings = <&kp LG(X)>;
            key-positions = <22 24>;         // X + V (skip middle)
            timeout-ms = <30>;
            require-prior-idle-ms = <150>;
        };

        // ── Tier 3: Vertical Symbol Combos ─────────────────────────

        combo_minus {
            bindings = <&kp MINUS>;
            key-positions = <16 27>;         // J + M (right index vertical)
            timeout-ms = <40>;
            require-prior-idle-ms = <100>;
        };

        combo_underscore {
            bindings = <&kp UNDER>;
            key-positions = <15 26>;         // H + N (right inner vertical)
            timeout-ms = <40>;
            require-prior-idle-ms = <100>;
        };

        combo_equal {
            bindings = <&kp EQUAL>;
            key-positions = <13 24>;         // F + V (left index vertical)
            timeout-ms = <40>;
            require-prior-idle-ms = <100>;
        };

        combo_grave {
            bindings = <&kp GRAVE>;
            key-positions = <11 22>;         // S + X (left ring vertical)
            timeout-ms = <40>;
            require-prior-idle-ms = <100>;
        };

        combo_semi {
            bindings = <&kp SEMI>;
            key-positions = <18 19>;         // L + ' (right ring+pinky home)
            timeout-ms = <30>;
            require-prior-idle-ms = <150>;
        };
    };

    macros {
        hyper: hyper {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press &kp LGUI &kp LALT &kp LCTRL &kp LSHFT>,
                <&macro_pause_for_release>,
                <&macro_release &kp LGUI &kp LALT &kp LCTRL &kp LSHFT>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

        base_layer {
            display-name = "BASE";
            //             ┏━━━━━━━━━━━┳━━━━━━━━━━━┳━━━━━━━━━━━┳━━━━━━━━━━━┳━━━━━━━━━━━┓   ┏━━━━━━━━━━━┳━━━━━━━━━━━┳━━━━━━━━━━━┳━━━━━━━━━━━┳━━━━━━━━━━━┓
            //             ┃     Q     ┃     W     ┃     E     ┃     R     ┃     T     ┃   ┃     Y     ┃     U     ┃     I     ┃     O     ┃     P     ┃
            //             ┣━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┫   ┣━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┫
            //             ┃  GUI/A    ┃  ALT/S    ┃  CTRL/D   ┃  SHFT/F   ┃     G     ┃   ┃     H     ┃  SHFT/J   ┃  CTRL/K   ┃  ALT/L    ┃  GUI/'    ┃
            //             ┣━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┫   ┣━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┫
            //             ┃     Z     ┃     X     ┃     C     ┃     V     ┃     B     ┃   ┃     N     ┃     M     ┃     ,     ┃     .     ┃     /     ┃
            // ┏━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┫   ┣━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┻━━━━━━━━━━━┛
            // ┃ CTRL/ESC  ┃ MEDIA/ESC ┃  NAV/SPC  ┃ MOUSE/TAB ┃           ┃           ┃   ┃  SYM/ENT  ┃ NUM/BSPC  ┃  FUN/DEL  ┃   HYPER   ┃
            // ┗━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━┛                           ┗━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━┛
            bindings = <
                &kp Q       &kp W       &kp E         &kp R         &kp T           &kp Y       &kp U         &kp I         &kp O        &kp P
                &mt LGUI A  &mt LALT S  &mt LCTRL D   &mt LSHFT F   &kp G           &kp H       &mt RSHFT J   &mt RCTRL K   &mt RALT L   &mt RGUI SQT
                &kp Z       &kp X       &kp C         &kp V         &kp B           &kp N       &kp M         &kp COMMA     &kp DOT      &kp FSLH
  &mt LCTRL ESC &lt MEDIA ESC &lt NAV SPACE &lt MOUSE TAB                 &lt SYM RET &lt NUM BSPC  &lt FUN DEL               &hyper
            >;
        };

        // ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

        nav_layer {
            display-name = "NAV";
            // Right hand: vim arrows (HJKL), clipboard, nav
            // Left hand: home row mods (transparent for hold layer)
            bindings = <
                &none       &none       &none         &none         &none           &kp LG(LS(Z)) &kp LG(V)  &kp LG(C)     &kp LG(X)    &kp LG(Z)
                &kp LGUI    &kp LALT    &kp LCTRL     &kp LSHFT     &none           &kp LEFT    &kp DOWN      &kp UP        &kp RIGHT    &kp CAPS
                &none       &none       &none         &none         &none           &kp INS     &kp HOME      &kp PG_DN     &kp PG_UP    &kp END
  &mt LCTRL ESC &none         &none         &none                               &kp RET     &kp BSPC      &kp DEL               &hyper
            >;
        };

        // ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

        num_layer {
            display-name = "NUM";
            // Left hand: number pad style
            // Right hand: home row mods
            bindings = <
                &kp LBKT    &kp N7      &kp N8        &kp N9        &kp RBKT        &none       &none         &none         &none        &none
                &kp SEMI    &kp N4      &kp N5        &kp N6        &kp EQUAL       &none       &kp RSHFT     &kp RCTRL     &kp RALT     &kp RGUI
                &kp GRAVE   &kp N1      &kp N2        &kp N3        &kp BSLH        &none       &none         &none         &none        &none
  &mt LCTRL ESC &kp DOT       &kp N0        &kp MINUS                           &none       &none         &none                 &hyper
            >;
        };

        // ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

        media_layer {
            display-name = "MEDIA";
            // Right hand: media controls + BT
            // Left hand: home row mods
            bindings = <
                &none       &none       &none         &none         &none           &none          &none          &none          &none          &none
                &kp LGUI    &kp LALT    &kp LCTRL     &kp LSHFT     &none           &kp C_PREV     &kp C_VOL_DN   &kp C_VOL_UP   &kp C_NEXT     &none
                &none       &none       &none         &none         &none           &bt BT_SEL 0   &bt BT_SEL 1   &bt BT_SEL 2   &bt BT_SEL 3   &bt BT_CLR
  &mt LCTRL ESC &none         &none         &none                               &kp C_STOP     &kp C_PP       &kp C_MUTE            &hyper
            >;
        };

        // ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

        sym_layer {
            display-name = "SYM";
            // Left hand: symbols
            // Right hand: home row mods
            bindings = <
                &kp LBRC    &kp AMPS    &kp ASTRK     &kp LPAR      &kp RBRC        &none       &none         &none         &none        &none
                &kp COLON   &kp DLLR    &kp PRCNT     &kp CARET     &kp PLUS        &none       &kp RSHFT     &kp RCTRL     &kp RALT     &kp RGUI
                &kp TILDE   &kp EXCL    &kp AT        &kp HASH      &kp PIPE        &none       &none         &none         &none        &none
  &mt LCTRL ESC &kp LPAR      &kp RPAR      &kp UNDER                           &none       &none         &none                 &hyper
            >;
        };

        // ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

        fun_layer {
            display-name = "FUN";
            // Left hand: function keys
            // Right hand: home row mods
            bindings = <
                &kp F12     &kp F7      &kp F8        &kp F9        &kp PSCRN       &none       &none         &none         &none        &none
                &kp F11     &kp F4      &kp F5        &kp F6        &kp SLCK        &none       &kp RSHFT     &kp RCTRL     &kp RALT     &kp RGUI
                &kp F10     &kp F1      &kp F2        &kp F3        &kp PAUSE_BREAK &none       &none         &none         &none        &none
  &mt LCTRL ESC &kp K_APP     &kp SPACE     &kp TAB                              &none       &none         &none                 &hyper
            >;
        };

        // ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄

        mouse_layer {
            display-name = "MOUSE";
            // Right hand: mouse movement, scroll, buttons
            // Left hand: home row mods
            bindings = <
                &none       &none       &none         &none         &none           &none            &none            &none          &none             &none
                &kp LGUI    &kp LALT    &kp LCTRL     &kp LSHFT     &none           &mmv MOVE_LEFT   &mmv MOVE_DOWN   &mmv MOVE_UP   &mmv MOVE_RIGHT   &none
                &none       &none       &none         &none         &none           &msc SCRL_LEFT   &msc SCRL_DOWN   &msc SCRL_UP   &msc SCRL_RIGHT   &none
  &mt LCTRL ESC &none         &none         &none                               &mkp MCLK        &mkp LCLK        &mkp RCLK             &hyper
            >;
        };
    };
};
